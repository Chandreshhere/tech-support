# Groq API keys (multi-key rotation)
GROQ_API_KEY_key_1=gsk_...
GROQ_API_KEY_key_2=gsk_...

# Gemini API keys (multi-key rotation)
GEMINI_API_KEY_key_1=AI...
GEMINI_API_KEY_key_2=AI...

# Optional: override defaults
# LLM_MODEL=gemini              # default provider (gemini for vision)
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash

# ChromaDB
CHROMA_URL=http://localhost:8000

# Embeddings model (downloaded on first run, ~80MB)
# EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
